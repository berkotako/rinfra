# RInfra DigitalOcean droplet environment.
#
# deploy/digitalocean/install.sh copies this to `.env` and fills in the generated
# secrets and password on first run. Never commit the real `.env`.

# --- Secrets (generated by install.sh; keep them safe) ----------------------

# Base64-encoded 32-byte AES-256 key encrypting stored cloud credentials at rest.
# Generate: openssl rand -base64 32   — CHANGING THIS makes existing stored
# engagement credentials undecryptable.
RINFRA_MASTER_KEY=

# Postgres password for the bundled database container.
POSTGRES_PASSWORD=

# Bootstrap admin password (username: admin). The server seeds NO admin unless
# this is set, and never defaults to admin/admin in production. Change it in
# Settings → Account after first login.
RINFRA_ADMIN_PASSWORD=

# Passphrase for the local Pulumi state backend (used by live provisioning).
PULUMI_CONFIG_PASSPHRASE=rinfra-local

# --- Public address ---------------------------------------------------------

# Caddy site address. Set to a domain you control that points an A record at this
# droplet's IP to get automatic HTTPS (Let's Encrypt). Leave as ":80" to serve
# plain HTTP on port 80 (IP-only / first boot). Example: console.example.com
RINFRA_SITE_ADDRESS=:80

# --- Optional ---------------------------------------------------------------

# Threat feed sources (comma-separated): "bundled" (offline snapshot, no egress)
# and/or "cisa-kev" (live CISA KEV catalog).
RINFRA_THREATFEED=bundled
