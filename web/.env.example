# RInfra web — environment variables
#
# REST mode: set this to the Go server's base URL.
# When set, the UI uses RestClient and talks to the live API.
# When unset, the UI uses MockClient (static demo mode — no Go server needed).
NEXT_PUBLIC_RINFRA_API=http://localhost:8080

# Operator identity sent in X-RInfra-Operator header (optional override).
# Defaults to "console-user".
# NEXT_PUBLIC_RINFRA_OPERATOR=your-handle
