# RInfra Docker environment. Copy to `.env` (scripts/install.sh does this for
# you and fills in generated secrets). Never commit the real `.env`.

# Base64-encoded 32-byte AES-256 key used to encrypt stored cloud credentials.
# Generate with: openssl rand -base64 32
RINFRA_MASTER_KEY=

# Passphrase for the local Pulumi state backend (used by live provisioning).
PULUMI_CONFIG_PASSPHRASE=rinfra-local

# API base URL the browser uses to reach the control plane. For a local Docker
# install this is the host-published server port.
NEXT_PUBLIC_RINFRA_API=http://localhost:8080

# Threat feed: which advisory resources to collect. Comma-separated source keys
# ("bundled" = offline snapshot, "cisa-kev" = live CISA KEV catalog). Add your
# own feeds in RInfra's Advisory JSON schema via _URLS / _FILES (see
# config/threatfeed.example.json). All selected sources are merged.
RINFRA_THREATFEED=bundled
# RINFRA_THREATFEED_URLS=https://intel.example.com/advisories.json
# RINFRA_THREATFEED_FILES=/etc/rinfra/threatfeed.json
